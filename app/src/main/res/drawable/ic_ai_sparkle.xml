<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="32dp"
    android:height="32dp"
    android:viewportWidth="32"
    android:viewportHeight="32">

    <!-- Main 4-pointed star -->
    <path
        android:pathData="M12,1 L13.4,9.6 L22,11 L13.4,12.4 L12,21 L10.6,12.4 L2,11 L10.6,9.6Z"
        android:fillColor="@color/ai_sparkle_main" />

    <!-- Small accent circle top-right -->
