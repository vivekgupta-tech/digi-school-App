        android:pathData="M19.5,4 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0"
        android:fillColor="@color/ai_sparkle_accent"
        android:fillAlpha="0.55" />

    <!-- Tiny accent circle left -->
    <path
        android:pathData="M4.5,5.5 m-1,0 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0"
        android:fillColor="@color/ai_sparkle_accent"
        android:fillAlpha="0.4" />

