<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔══════════════════════════════════════════════════════════════╗
    ║   res/layout/activity_splash.xml                            ║
    ║   Splash Screen — Logo in rotating dashed circle            ║
    ║   Day + Night mode supported via theme colors               ║
    ╚══════════════════════════════════════════════════════════════╝
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg"
    android:clipChildren="false">

    <!-- ── Decorative background circles ── -->
    <View
        android:id="@+id/decoCircle1"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_deco_circle_1"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="-80dp"
        android:layout_marginStart="-80dp" />

    <View
        android:id="@+id/decoCircle2"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/bg_deco_circle_2"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="-30dp"
        android:layout_marginEnd="-90dp" />

    <!-- ── Rotating dashed ring (outer) ── -->
    <ImageView
        android:id="@+id/ringRotate"
        android:layout_width="172dp"
        android:layout_height="172dp"
        android:src="@drawable/ic_splash_ring_dashed"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="60dp" />

    <!-- ── Static subtle inner ring ── -->
    <ImageView
        android:id="@+id/ringInner"
        android:layout_width="144dp"
        android:layout_height="144dp"
        android:src="@drawable/ic_splash_ring_solid"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="@id/ringRotate"
        app:layout_constraintBottom_toBottomOf="@id/ringRotate"
        app:layout_constraintStart_toStartOf="@id/ringRotate"
        app:layout_constraintEnd_toEndOf="@id/ringRotate" />

    <!-- ── Logo (book SVG) inside the circle ── -->
    <ImageView
        android:id="@+id/logoBook"
        android:layout_width="72dp"
        android:layout_height="88dp"
        android:src="@drawable/ic_logo_book"
        android:scaleType="fitCenter"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="@id/ringRotate"
        app:layout_constraintBottom_toBottomOf="@id/ringRotate"
        app:layout_constraintStart_toStartOf="@id/ringRotate"
        app:layout_constraintEnd_toEndOf="@id/ringRotate" />

    <!-- ── AI sparkle / star above logo ── -->
    <ImageView
        android:id="@+id/aiStar"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_ai_sparkle"
        android:alpha="0"
        app:layout_constraintBottom_toTopOf="@id/logoBook"
        app:layout_constraintStart_toStartOf="@id/logoBook"
        app:layout_constraintEnd_toEndOf="@id/logoBook"
        android:layout_marginBottom="2dp" />

    <!-- ── Brand name: DigiSchool ── -->
        <TextView
            android:id="@+id/tvBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_brand"
            android:textSize="30sp"
            android:letterSpacing="-0.02"
            app:fontFamily="@font/poppins_bold"
            android:textColor="@color/splash_brand_text"
            android:alpha="0"
            app:layout_constraintTop_toBottomOf="@id/ringRotate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

    <!--
        NOTE: "Digi" in brand_primary color, "School" in lighter weight is
        achieved via a SpannableString in SplashActivity.kt — the TextView
        above shows the combined string for layout purposes.
    -->

    <!-- ── Slogan ── -->
    <TextView
        android:id="@+id/tvSlogan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_slogan"
        android:textSize="11sp"
        android:letterSpacing="0.18"
        android:textAllCaps="true"
        app:fontFamily="@font/poppins"
        android:textColor="@color/splash_slogan_text"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/tvBrand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="7dp" />

    <!-- ── Loading dots ── -->
    <LinearLayout
        android:id="@+id/dotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:alpha="0"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="52dp">

        <View
            android:id="@+id/dot1"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_loading_dot"
            android:layout_marginEnd="7dp" />

        <View
            android:id="@+id/dot2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_loading_dot"
            android:layout_marginEnd="7dp" />

        <View
            android:id="@+id/dot3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_loading_dot" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>